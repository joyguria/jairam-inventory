<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial; padding: 20px; }
        .title { font-size: 22px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        table, th, td { border: 1px solid #000; padding: 8px; }
    </style>
</head>
<body>
    <div class="title">Investment Report</div>

    <p>Name: <%= name %></p>
    <p>Total Investment: ₹<%= investment %></p>
    <p>Monthly Profit: ₹<%= profit %></p>

    <table>
        <tr>
            <th>Date</th>
            <th>Amount</th>
        </tr>
        <% transactions.forEach(tx => { %>
            <tr>
                <td><%= tx.date %></td>
                <td>₹<%= tx.amount %></td>
            </tr>
        <% }) %>
    </table>
</body>
</html>